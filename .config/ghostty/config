bold-is-bright = true

# theme = rose-pine-moon
theme = catppuccin-mocha
macos-titlebar-style = hidden

font-family = Maple Mono NF
font-size = 14
font-variation = wght=600
font-variation-bold = wght=700

font-feature = zero
font-feature = calt
font-feature = ss01

background-blur-radius = 20
background-opacity = 0.95
unfocused-split-opacity = 0.7


# Keybinds
keybind = super+alt+l=goto_split:right
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:bottom
keybind = super+alt+k=goto_split:top
# Shift+Enter -> newline in Claude Code:
# Do NOT bind shift+enter=text:\n here. That injects a raw LF, which tmux
# collapses back into a plain Enter, so it can't survive the tmux layer.
# Instead we leave Shift+Enter unbound so Ghostty emits the kitty keyboard
# protocol sequence (\x1b[13;2u), which tmux forwards (extended-keys on +
# extended-keys-format csi-u) and Claude Code decodes as a newline. Works in
# bare Ghostty, through tmux, and through herdr.
